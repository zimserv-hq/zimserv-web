{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "zimserv.co.zw" }
      ],
      "destination": "https://www.zimserv.co.zw/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/admin/:path*",
      "has": [
        { "type": "host", "value": "www.zimserv.co.zw" }
      ],
      "destination": "/404.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/legal/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "X-Robots-Tag",
          "value": "all"
        }
      ]
    }
  ]
}
